.tthc .tabs:after {
  content: "";
  display: block;
  clear: both;
}
.tthc .tabs > li {
  float: left;
}
.tthc .tabs > li > a {
  display: block;
  background: #E9F0F8;
  padding: 10px 20px;
  border: 1px solid transparent;
  border-bottom: 0px;
  position: relative;
  font-weight: 500;
}
.tthc .tabs > li.active > a {
  border-color: #C9CDCF;
  background: #fff;
}
.tthc .tabs > li.active > a:after {
  content: "";
  height: 2px;
  background: #fff;
  position: absolute;
  bottom: -1px;
  left: 0px;
  right: 0px;
}
@media (max-width: 768px) {
